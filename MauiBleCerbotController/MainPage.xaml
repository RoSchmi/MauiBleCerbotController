<base:BaseContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                      xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                      xmlns:base="clr-namespace:MauiBleCerbotController.Infrastructure"
                      xmlns:vm="clr-namespace:MauiBleCerbotController.ViewModels"
                      xmlns:scan="clr-namespace:Bluetooth.Abstractions.Scanning;assembly=Bluetooth.Abstractions.Scanning"
                      xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
                      x:Class="MauiBleCerbotController.MainPage"
                      x:TypeArguments="vm:MainPageViewModel"
                      x:DataType="vm:MainPageViewModel">

    <!-- ="BLE Scanner">  -->

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">
            <Image
                Source="dotnet_bot.png"
                HeightRequest="185"
                Aspect="AspectFit"
                SemanticProperties.Description="dot net bot in a submarine number ten" />
            <HorizontalStackLayout Spacing="15">
                <Label Text="IsScanning"
                       MinimumHeightRequest="50"
                       BackgroundColor="{Binding IsScanning, 
                       Converter={StaticResource BoolToColorConverter}}"/>
                <Button Text="Refresh Scanning State"  Command="{Binding RefreshScanStateCommand}"/>

                <Picker BackgroundColor="BlanchedAlmond"
                            MinimumWidthRequest="200"
                            ItemsSource="{Binding Devices}"
                            ItemDisplayBinding="{Binding .}"
                            SelectedItem="{Binding SelectedDevice}" />

            </HorizontalStackLayout>

            <Label
                Text="Hello, World!"
                Style="{StaticResource Headline}"
                SemanticProperties.HeadingLevel="Level1" />

            <Label
                Text="Welcome to &#10;.NET Multi-platform App UI"
                Style="{StaticResource SubHeadline}"
                SemanticProperties.HeadingLevel="Level2"
                SemanticProperties.Description="Welcome to dot net Multi platform App U I" />

            <Button  
                Text="Scan for Ble Devices" 
                Command="{Binding StartScanCommand}"
                HorizontalOptions="Center"/>

            <Button  
                Text="Stop Scanning" 
                Command="{Binding StopScanCommand}"
                HorizontalOptions="Center"/>




        </VerticalStackLayout>
    </ScrollView>

</base:BaseContentPage>
